{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDirs": [
      "Api",
      "Code",
      "Module"
    ],
    "paths": {
      "module:*": [
        "./Module/*/index.ts"
      ]
    },
    "noEmit": true,
    "allowJs": false,
    "checkJs": false,
    "skipLibCheck": true
  },
  "include": [
    "Api/*.ts",
    "Code/*.ts",
    "Module/**/*.ts",
    "kooboo.project.d.ts",
    "types.kooboo.d.ts"
  ],
  "exclude": [
    "node_modules",
    "Vue",
    "Script",
    "Style"
  ]
}
